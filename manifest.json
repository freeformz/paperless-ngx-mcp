{
  "manifest_version": "0.3",
  "name": "paperless-ngx-mcp",
  "display_name": "Paperless-ngx MCP",
  "version": "0.0.0",
  "description": "MCP server for Paperless-ngx document management. Search, browse, and manage documents and metadata.",
  "author": {
    "name": "freeformz",
    "url": "https://github.com/freeformz"
  },
  "user_config": {
    "paperless_url": {
      "type": "string",
      "title": "Paperless-ngx URL",
      "description": "Base URL of your Paperless-ngx instance (e.g. http://localhost:8000)",
      "default": "http://localhost:8000",
      "required": true
    },
    "paperless_token": {
      "type": "string",
      "title": "Paperless-ngx API Token",
      "description": "API authentication token. Generate one in Paperless-ngx under Settings > Administration > Auth Tokens.",
      "required": true,
      "sensitive": true
    }
  },
  "server": {
    "type": "binary",
    "entry_point": "server/paperless-ngx-mcp",
    "mcp_config": {
      "command": "${__dirname}/server/paperless-ngx-mcp",
      "args": ["mcp"],
      "env": {
        "PAPERLESS_URL": "${user_config.paperless_url}",
        "PAPERLESS_TOKEN": "${user_config.paperless_token}"
      },
      "platform_overrides": {
        "win32": {
          "command": "${__dirname}/server/paperless-ngx-mcp.exe",
          "args": ["mcp"]
        }
      }
    }
  },
  "tools": [
    {"name": "document_list", "description": "Search and list documents"},
    {"name": "document_get", "description": "Get document details"},
    {"name": "document_update", "description": "Update document metadata"},
    {"name": "tag_list", "description": "List tags"},
    {"name": "correspondent_list", "description": "List correspondents"},
    {"name": "document_type_list", "description": "List document types"}
  ],
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"]
  }
}
